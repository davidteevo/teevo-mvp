# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# App (for Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Shippo (shipping labels)
SHIPPO_API_TOKEN=shippo_live_...   # or shippo_test_... for test mode
# Optional: DPD UK carrier account object ID from Shippo (Settings → Carriers). Use if "no shipping rates" in test mode.
SHIPPO_DPD_CARRIER_ACCOUNT_ID=f2635d1716fb47aab349d6b91cc9c821

# Resend (auth emails: signup + forgot password; also transactional emails)
RESEND_API_KEY=re_...

# Supabase Auth Send Email hook (use Resend instead of Supabase SMTP)
# From Dashboard → Auth → Hooks → Send Email → secret (format: v1,whsec_<base64>)
SEND_EMAIL_HOOK_SECRET=v1,whsec_...

# Admin (packaging, feedback – comma-separated). Set the real address in .env.local (this file is only a template; the app does not load it).
TEEVO_ADMIN_EMAILS=admin@teevohq.com

# Seller onboarding: book-a-call link (optional)
# Booking Link (Teevo Seller Feedback Booking Link)
NEXT_PUBLIC_BOOK_CALL_URL=https://calendar.app.google/84fuiARU1YNdpcPm8

# AI (Phase 1: search intent, listing enhancement). Server-side only; never expose to client.
OPENAI_API_KEY=sk-...